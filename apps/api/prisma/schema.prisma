generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionType {
  BASIC
  PREMIUM
  FAST_SERVE
}

enum EventType {
  WEDDING
  KHITANAN
  BIRTHDAY
  AQIQAH
  ENGAGEMENT
  GRADUATION
  REUNION
  CORPORATE
  SYUKURAN
  ANNIVERSARY
  WALIMAH
  CUSTOM
}

enum Attendance {
  ATTENDING
  NOT_ATTENDING
  MAYBE
  PENDING
}

enum MediaPurpose {
  GALLERY
  COVER
  PROFILE
  MUSIC
}

enum LayoutType {
  SCROLL
  SLIDE
}

model User {
  id                     String            @id @default(uuid())
  email                  String            @unique
  passwordHash           String            @map("password_hash")
  fullName               String            @map("full_name")
  phone                  String?
  avatarUrl              String?           @map("avatar_url")
  dateOfBirth            DateTime?         @map("date_of_birth") @db.Date
  address                String?
  role                   Role              @default(USER)
  subscriptionType       SubscriptionType  @default(BASIC) @map("subscription_type")
  subscriptionExpireDate DateTime?         @map("subscription_expire_date")
  maxGuests              Int               @default(300) @map("max_guests")
  isEmailVerified        Boolean           @default(false) @map("is_email_verified")
  emailVerifyToken       String?           @map("email_verify_token")
  emailVerifyExpires     DateTime?         @map("email_verify_expires")
  isFirstLogin           Boolean           @default(true) @map("is_first_login")
  isDeleted              Boolean           @default(false) @map("is_deleted")
  deletedAt              DateTime?         @map("deleted_at")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  invitations        Invitation[]
  media              Media[]
  guestLimitRequests GuestLimitRequest[]
  notifications      Notification[]
  bugFeedbacks       BugFeedback[]

  @@map("users")
}

model Invitation {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  slug          String       @unique
  title         String
  eventType     EventType    @map("event_type")
  coverImageUrl String?      @map("cover_image_url")
  openingText   String?      @map("opening_text")
  closingText   String?      @map("closing_text")
  story         String?
  musicUrl      String?      @map("music_url")
  isPublished   Boolean      @default(false) @map("is_published")
  isActive      Boolean      @default(true) @map("is_active")
  viewCount     Int          @default(0) @map("view_count")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  events         InvitationEvent[]
  personProfiles PersonProfile[]
  guests         Guest[]
  rsvps          Rsvp[]
  media          Media[]
  giftAccounts   GiftAccount[]
  coInvitors     CoInvitor[]
  templates      InvitationTemplate[]
  comments       InvitationComment[]

  @@index([userId])
  @@map("invitations")
}

model InvitationEvent {
  id           String   @id @default(uuid())
  invitationId String   @map("invitation_id")
  eventName    String   @map("event_name")
  eventDate    String   @map("event_date")
  startTime    String   @map("start_time")
  endTime      String?  @map("end_time")
  venueName    String?  @map("venue_name")
  venueAddress String?  @map("venue_address")
  mapUrl       String?  @map("map_url")
  latitude     Float?
  longitude    Float?
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@map("invitation_events")
}

model PersonProfile {
  id           String   @id @default(uuid())
  invitationId String   @map("invitation_id")
  fullName     String   @map("full_name")
  nickname     String?
  photoUrl     String?  @map("photo_url")
  parentFather String?  @map("parent_father")
  parentMother String?  @map("parent_mother")
  childOrder    String?  @map("child_order")
  role          String   @default("primary")
  instagram     String?
  dateOfBirth   String?  @map("date_of_birth")
  bio           String?
  gender        String?
  address       String?
  phone         String?
  age           String?
  jobTitle      String?  @map("job_title")
  organization  String?
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@map("person_profiles")
}

model Template {
  id           String     @id @default(uuid())
  name         String     @unique
  slug         String     @unique
  thumbnailUrl String?    @map("thumbnail_url")
  category     String
  tags                String[]
  supportedEventTypes String[]   @default([]) @map("supported_event_types")
  cssClass            String     @map("css_class")
  layoutType          LayoutType @default(SCROLL) @map("layout_type")
  usageCount   Int        @default(0) @map("usage_count")
  ratingAvg    Float      @default(0) @map("rating_avg")
  ratingCount  Int        @default(0) @map("rating_count")
  isPremium    Boolean    @default(false) @map("is_premium")
  isActive     Boolean    @default(true) @map("is_active")
  sortOrder    Int        @default(0) @map("sort_order")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  invitations  InvitationTemplate[]
  testimonials Testimonial[]

  @@index([category])
  @@map("templates")
}

model InvitationTemplate {
  id           String  @id @default(uuid())
  invitationId String  @map("invitation_id")
  templateId   String  @map("template_id")
  isPrimary    Boolean @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  template   Template   @relation(fields: [templateId], references: [id])

  @@unique([invitationId, templateId])
  @@map("invitation_templates")
}

model Guest {
  id           String   @id @default(uuid())
  invitationId String   @map("invitation_id")
  name         String
  phone        String?
  email        String?
  groupName    String?  @map("group_name")
  isSent       Boolean  @default(false) @map("is_sent")
  sentAt       DateTime? @map("sent_at")
  sentVia      String?  @map("sent_via")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  rsvps      Rsvp[]

  @@index([invitationId])
  @@map("guests")
}

model Rsvp {
  id           String     @id @default(uuid())
  invitationId String     @map("invitation_id")
  guestId      String?    @map("guest_id")
  guestName    String     @map("guest_name")
  message      String?
  attendance   Attendance @default(PENDING)
  numGuests    Int        @default(1) @map("num_guests")
  isApproved   Boolean    @default(true) @map("is_approved")
  createdAt    DateTime   @default(now()) @map("created_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  guest      Guest?     @relation(fields: [guestId], references: [id])

  @@index([invitationId])
  @@map("rsvps")
}

model Media {
  id           String       @id @default(uuid())
  invitationId String?      @map("invitation_id")
  userId       String?      @map("user_id")
  fileUrl      String       @map("file_url")
  fileType     String       @map("file_type")
  fileSize     Int?         @map("file_size")
  originalName String?      @map("original_name")
  purpose      MediaPurpose
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")

  invitation Invitation? @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id])

  @@index([invitationId])
  @@map("media")
}

model GiftAccount {
  id            String   @id @default(uuid())
  invitationId  String   @map("invitation_id")
  bankName      String   @map("bank_name")
  accountNumber String   @map("account_number")
  accountHolder String   @map("account_holder")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@map("gift_accounts")
}

model CoInvitor {
  id           String   @id @default(uuid())
  invitationId String   @map("invitation_id")
  name         String
  title        String?
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@map("co_invitors")
}

model InvitationComment {
  id           String   @id @default(uuid())
  invitationId String   @map("invitation_id")
  name         String
  message      String
  createdAt    DateTime @default(now()) @map("created_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@map("invitation_comments")
}

model Testimonial {
  id               String   @id @default(uuid())
  userId           String?  @map("user_id")
  templateId       String?  @map("template_id")
  userName         String   @map("user_name")
  message          String
  rating           Int      @default(5)
  ratingDesain     Int      @default(5) @map("rating_desain")
  ratingKemudahan  Int      @default(5) @map("rating_kemudahan")
  ratingLayanan    Int      @default(5) @map("rating_layanan")
  notes            String?
  isApproved       Boolean  @default(false) @map("is_approved")
  createdAt        DateTime @default(now()) @map("created_at")

  template Template? @relation(fields: [templateId], references: [id])

  @@unique([userId, templateId])
  @@index([userId])
  @@index([templateId])
  @@map("testimonials")
}

model SiteSetting {
  id          String   @id @default(uuid())
  category    String   @default("contact")
  item        String
  value       String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

enum GuestLimitRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model GuestLimitRequest {
  id              String                  @id @default(uuid())
  userId          String                  @map("user_id")
  invitationId    String?                 @map("invitation_id")
  currentLimit    Int                     @map("current_limit")
  requestedAmount Int                     @map("requested_amount")
  reason          String?
  status          GuestLimitRequestStatus @default(PENDING)
  adminNote       String?                 @map("admin_note")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("guest_limit_requests")
}

enum NotificationType {
  PREMIUM_REQUEST
  GUEST_LIMIT_REQUEST
  TESTIMONIAL_NEW
  BUG_FEEDBACK_NEW
  REQUEST_APPROVED
  REQUEST_REJECTED
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  linkUrl   String?          @map("link_url")
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

enum BugFeedbackStatus {
  UNHANDLED
  HANDLED
}

model BugFeedback {
  id          String            @id @default(uuid())
  userId      String            @map("user_id")
  userName    String            @map("user_name")
  subject     String
  message     String
  category    String            @default("bug")
  status      BugFeedbackStatus @default(UNHANDLED)
  adminNote   String?           @map("admin_note")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("bug_feedbacks")
}
