# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invitee_db

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION=1d

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Storage - 'local' | 's3'
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# SMTP (Email) — optional, used for email verification
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@invitee.id

# Frontend URL (used for email verification links)
FRONTEND_URL=http://localhost:3000

# S3 / Cloudflare R2 (fill when STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
